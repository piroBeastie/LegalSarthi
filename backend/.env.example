# ═══════════════════════════════════════════
# LegalSarthi — Environment Configuration
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════

# ── App Settings ──
APP_NAME=LegalSarthi
DEBUG=false

# ── MongoDB ──
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=legalsarthi

# ── JWT Auth ──
# REQUIRED: Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-here

# ── Gemini AI ──
# Get your API key from: https://aistudio.google.com/apikey
# NO quotes around the key!
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
